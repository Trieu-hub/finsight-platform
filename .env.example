# Template for the local secrets file consumed by docker-compose.yml.
# Copy to `.env` and fill in real values:  cp .env.example .env
# `.env` is gitignored — NEVER commit real secrets.
#
# Generate strong values (Linux/macOS/Git-Bash):
#   JWT_SECRET:        openssl rand -base64 64 | tr -d '\n'
#   any DB password:   openssl rand -base64 24 | tr -d '/+=\n'
# On Windows PowerShell:
#   [Convert]::ToBase64String((1..64 | % {Get-Random -Max 256}))

# Shared HMAC secret for JWT signing/validation. MUST be >= 256 bits (44+ base64 chars).
# No default exists in the apps — services fail to start if this is unset.
JWT_SECRET=

# MySQL root password — container init/admin only; the services never use it.
MYSQL_ROOT_PASSWORD=

# Per-service database passwords. Each maps to a dedicated, single-database user
# (auth_user/user_user/transaction_user/budget_user/risk_user/notification_user/
# analytics_user) created at MySQL init.
AUTH_DB_PASSWORD=
USER_DB_PASSWORD=
TRANSACTION_DB_PASSWORD=
BUDGET_DB_PASSWORD=
RISK_DB_PASSWORD=
NOTIFICATION_DB_PASSWORD=
ANALYTICS_DB_PASSWORD=

# Optional: LLM features on any OpenAI-compatible API. Two independent consumers share
# the same LLM_* provider contract:
#   * notification-service — narrates risk alerts (FINSIGHT_NARRATOR_AI_ENABLED)
#   * analytics-service     — writes the monthly summary (FINSIGHT_SUMMARIZER_AI_ENABLED)
# Default provider is Groq (free tier — get a key at https://console.groq.com).
# Leave both disabled to use the rule-based/template paths. To turn a feature on, flip its
# flag to true AND set LLM_API_KEY:
#   FINSIGHT_NARRATOR_AI_ENABLED=true
#   FINSIGHT_SUMMARIZER_AI_ENABLED=true
#   LLM_API_KEY=gsk_...          # gitignored, never commit it
# Switch providers without code changes by overriding LLM_BASE_URL + LLM_MODEL, e.g.
#   OpenAI:     LLM_BASE_URL=https://api.openai.com/v1   LLM_MODEL=gpt-4o-mini
#   OpenRouter: LLM_BASE_URL=https://openrouter.ai/api/v1 LLM_MODEL=...:free
#   Ollama:     LLM_BASE_URL=http://host.docker.internal:11434/v1 LLM_MODEL=llama3.1
FINSIGHT_NARRATOR_AI_ENABLED=false
FINSIGHT_SUMMARIZER_AI_ENABLED=false
LLM_API_KEY=
