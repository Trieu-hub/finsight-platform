{
  "uid": "finsight-consumer-lag",
  "title": "FinSight Consumer Lag",
  "tags": ["finsight", "kafka"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Max consumer lag (records, all groups)",
      "description": "Highest per-consumer records-lag-max across every consuming service. Sustained non-zero = a consumer is falling behind its topic.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 100 },
            { "color": "red", "value": 1000 }
          ] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [
        { "refId": "A", "expr": "max(kafka_consumer_fetch_manager_records_lag_max)" }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total consumer lag (records, all groups)",
      "description": "Sum of current per-partition lag across all assigned partitions of every consumer.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 100 },
            { "color": "red", "value": 1000 }
          ] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [
        { "refId": "A", "expr": "sum(kafka_consumer_fetch_manager_records_lag)" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Consuming services reporting lag",
      "description": "Number of scrape targets currently exporting the consumer-lag metric (sanity check that instrumentation is live).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "targets": [
        { "refId": "A", "expr": "count(count by (job) (kafka_consumer_fetch_manager_records_lag_max))" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Max consumer lag by service (records)",
      "description": "kafka_consumer_fetch_manager_records_lag_max per consuming service (job). The primary backlog SLI.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 5 },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "max by (job) (kafka_consumer_fetch_manager_records_lag_max)",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Total partition lag by service (records)",
      "description": "sum by (job) of kafka_consumer_fetch_manager_records_lag — aggregate of every assigned partition's lag per service.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 5 },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (job) (kafka_consumer_fetch_manager_records_lag)",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Per-partition lag (records) — job / topic / partition",
      "description": "Fine-grained lag for drill-down: one series per consumer/topic/partition.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "kafka_consumer_fetch_manager_records_lag",
          "legendFormat": "{{job}} / {{topic}} / {{partition}}"
        }
      ]
    }
  ]
}
