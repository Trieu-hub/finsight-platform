{
  "uid": "finsight-risk",
  "title": "FinSight Risk",
  "tags": ["finsight", "risk"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Detected risks (total)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [
        { "refId": "A", "expr": "sum(finsight_risk_events_detected_total)" }
      ]
    },
    {
      "id": 2,
      "type": "piechart",
      "title": "Risks by type",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 9, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "pieType": "donut",
        "legend": { "displayMode": "table", "placement": "right", "values": ["value"] }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (type) (finsight_risk_events_detected_total)",
          "legendFormat": "{{type}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "piechart",
      "title": "Risks by severity",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 9, "x": 15, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "pieType": "donut",
        "legend": { "displayMode": "table", "placement": "right", "values": ["value"] }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (severity) (finsight_risk_events_detected_total)",
          "legendFormat": "{{severity}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Detected risks — cumulative by type",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (type) (finsight_risk_events_detected_total)",
          "legendFormat": "{{type}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Detection rate (events/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "cps", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (type) (rate(finsight_risk_events_detected_total[5m]))",
          "legendFormat": "{{type}}"
        }
      ]
    }
  ]
}
